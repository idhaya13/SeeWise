# ============================================================
# SeeWise - Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys
# All APIs below are FREE to use!
# ============================================================

# TMDB (The Movie Database) - FREE API
# Sign up at: https://www.themoviedb.org/signup
# Get API key at: https://www.themoviedb.org/settings/api
# Free tier: 40 requests/10 seconds, no monthly limit
REACT_APP_TMDB_API_KEY=your_tmdb_api_key_here
REACT_APP_TMDB_BASE_URL=https://api.themoviedb.org/3
REACT_APP_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p

# Open Library (Books) - COMPLETELY FREE, No API key needed!
# Docs: https://openlibrary.org/developers/api
# No registration required, unlimited requests
REACT_APP_OPEN_LIBRARY_BASE=https://openlibrary.org

# Google Books API - FREE (1,000 requests/day without key, 1M/day with free key)
# Get free key at: https://console.cloud.google.com (enable Books API)
# No billing required for free tier
REACT_APP_GOOGLE_BOOKS_API_KEY=your_google_books_key_here
REACT_APP_GOOGLE_BOOKS_BASE=https://www.googleapis.com/books/v1

# Anthropic Claude API - For AI Recommendations
# Sign up at: https://console.anthropic.com
# Free $5 credit on signup
REACT_APP_CLAUDE_API_KEY=your_claude_api_key_here

# ============================================================
# FREE API SUMMARY:
# ============================================================
# 1. TMDB       → https://themoviedb.org/signup   (FREE, no CC)
# 2. Open Library→ https://openlibrary.org/dev     (FREE, no key needed)
# 3. Google Books→ https://console.cloud.google.com (FREE 1k/day)
# 4. Claude API  → https://console.anthropic.com   (FREE $5 credit)
# ============================================================
